# Application database owned by the deploying company.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/anos

# Encrypts workspace-scoped connector credentials before storage.
ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Select `mock` for the secret-free demo or `openai` for live inference.
MODEL_PROVIDER=mock
OPENAI_API_KEY=

# Public application URL used for authentication callbacks.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
